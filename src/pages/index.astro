---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import StickerCard from '../components/StickerCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SectionBadge from '../components/SectionBadge.astro';
import PillButton from '../components/PillButton.astro';
---

<BaseLayout>
  <div class="flex justify-end pt-4">
    <ThemeToggle />
  </div>
  <main class="flex min-h-[60vh] flex-col justify-center gap-4 py-16">
    <h1 class="font-display text-5xl font-bold text-text">
      bekapod<span class="text-pink">.</span>
    </h1>
    <p class="max-w-[44ch] text-soft">Placeholder</p>

    <section aria-labelledby="notes-heading">
      <SectionHeader
        as="h2"
        id="notes-heading"
        label="notes"
        color="pink"
        subtitle="little thoughts, posted straight to Bluesky"
      />
      <div class="grid gap-4 sm:grid-cols-2">
        <StickerCard>
          <p class="text-soft">Static card · default radius &amp; shadow</p>
        </StickerCard>
        <StickerCard as="a" href="#" interactive radius="card-lg" shadow="lg">
          <p class="font-display font-bold text-text">Interactive card</p>
          <p class="text-soft">Hover to lift &amp; deepen the shadow</p>
        </StickerCard>
      </div>
    </section>

    <div class="flex flex-wrap gap-3">
      <SectionBadge label="notes" color="pink" />
      <SectionBadge label="blog" color="coral" />
      <SectionBadge label="projects" color="teal" />
      <SectionBadge label="making" color="green" textColor="ink" />
      <SectionBadge label="now" color="purple" />
      <SectionBadge label="links" color="yellow" textColor="ink" />
    </div>

    <div class="flex flex-col gap-4">
      <div class="flex flex-wrap items-center gap-3">
        <PillButton href="#" color="ink" textColor="white">
          <span class="size-2 rounded-full bg-yellow" aria-hidden="true"></span>GitHub
        </PillButton>
        <PillButton href="#" color="blue" textColor="white">
          <span class="size-2 rounded-full bg-white" aria-hidden="true"></span>Bluesky
        </PillButton>
        <PillButton href="#" color="orange" textColor="ink">
          <span class="size-2 rounded-full bg-ink" aria-hidden="true"></span>RSS
        </PillButton>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <PillButton color="purple" textColor="white" size="sm">say hi</PillButton>
        <PillButton color="yellow" textColor="ink" size="sm">&larr; back home</PillButton>
        <PillButton href="#" color="blue" textColor="white" size="lg"
          >view full feed on Bluesky &rarr;</PillButton
        >
      </div>

      <div class="flex">
        <PillButton
          href="#"
          color="blue"
          textColor="white"
          size="lg"
          class="shadow-[2.5px_2.5px_0_var(--color-pink)] hover:shadow-[4px_4px_0_var(--color-pink)]"
        >
          find me on Bluesky &rarr;
        </PillButton>
      </div>
    </div>
  </main>
</BaseLayout>
