---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Notes from '../components/Notes.astro';
import BlogList from '../components/BlogList.astro';
import TerminalCard from '../components/TerminalCard.astro';
import { getNotes } from '../lib/pds/notes.ts';
import { getBlogPosts } from '../lib/pds/documents.ts';

const [notes, posts] = await Promise.all([getNotes(), getBlogPosts()]);
---

<BaseLayout>
  <Header slot="header" />
  <main>
    <Hero>
      <TerminalCard />
    </Hero>
    <Notes {notes} />
    <BlogList {posts} />
  </main>
</BaseLayout>
