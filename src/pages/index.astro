---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import StickerCard from '../components/StickerCard.astro';
---

<BaseLayout>
  <div class="flex justify-end pt-4">
    <ThemeToggle />
  </div>
  <main class="flex min-h-[60vh] flex-col justify-center gap-4 py-16">
    <h1 class="font-display text-5xl font-bold text-text">
      bekapod<span class="text-pink">.</span>
    </h1>
    <p class="max-w-[44ch] text-soft">Placeholder</p>

    <section class="grid gap-4 sm:grid-cols-2">
      <StickerCard>
        <p class="text-soft">Static card · default radius &amp; shadow</p>
      </StickerCard>
      <StickerCard as="a" href="#" interactive radius="card-lg" shadow="lg">
        <p class="font-display font-bold text-text">Interactive card</p>
        <p class="text-soft">Hover to lift &amp; deepen the shadow</p>
      </StickerCard>
    </section>
  </main>
</BaseLayout>
