---
import type { HTMLTag } from 'astro/types';
import SectionBadge from './SectionBadge.astro';

type Accent = 'pink' | 'coral' | 'teal' | 'yellow' | 'purple' | 'green' | 'orange' | 'blue' | 'ink';
type TextColor = 'white' | 'ink';

interface Props {
  /** Element the badge renders as — pass a heading (e.g. `h2`) to anchor `aria-labelledby`. */
  as?: HTMLTag;
  /** Forwarded to the badge so a section can reference it via `aria-labelledby`. */
  id?: string;
  /** Badge text. */
  label: string;
  /** Accent background token for the badge. */
  color?: Accent;
  /** Badge foreground colour. */
  textColor?: TextColor;
  /** Muted descriptive line beside the badge. */
  subtitle?: string;
  class?: string;
}

const { as = 'span', id, label, color, textColor, subtitle, class: className }: Props = Astro.props;
---

<header class:list={['mb-[26px] flex flex-wrap items-baseline gap-4', className]}>
  <SectionBadge {as} {id} {label} {color} {textColor} />
  {subtitle && <p class="mt-1.5 text-[15px] font-medium text-muted">{subtitle}</p>}
</header>
