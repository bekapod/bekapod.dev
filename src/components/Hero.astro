---
import { profiles } from '../data/profiles';
import Icon from './Icon.astro';
import PillButton from './PillButton.astro';

const pills = [profiles.github, profiles.bluesky, profiles.ravelry, profiles.rss];
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="grid grid-cols-1 items-center gap-[clamp(28px,5vw,56px)] py-[clamp(36px,7vw,84px)] md:grid-cols-2"
>
  <div class="text-center md:text-left">
    <p class="mb-2 text-base font-bold tracking-[1.5px] uppercase">Hi, I'm</p>

    <h1
      id="hero-heading"
      class="mb-[18px] font-display text-[clamp(52px,10vw,104px)] leading-[0.94] font-bold tracking-[-2.5px]"
    >
      bekapod<span class="text-pink" aria-hidden="true">.</span>
    </h1>

    <p
      class="mx-auto mb-[14px] max-w-[34ch] text-[clamp(17px,2.4vw,21px)] font-semibold text-pretty md:mx-0"
    >
      Software engineer building delightful things on the web.
    </p>

    <p class="mx-auto mb-6 max-w-[44ch] text-base leading-relaxed text-pretty text-soft md:mx-0">
      I write notes, the odd longer post, craft, and ship small hobby projects. Everything here is
      stuff that brings me joy. Have a poke around.
    </p>

    <div class="flex flex-wrap justify-center gap-2.5 md:justify-start">
      {
        pills.map((pill) => (
          <PillButton href={pill.href} color={pill.color}>
            <Icon icon={pill.icon} />
            {pill.name}
          </PillButton>
        ))
      }
    </div>
  </div>

  <div class="hidden md:block">
    <slot />
  </div>
</section>
